  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100 absolute w-full shadow-xl">
    <div class="px-6 py-4 space-y-4 flex flex-col">
      <a href="#services" class="mobile-link block text-lg font-medium text-[#334155] hover:text-[#0284c7] py-2">Services</a>
      <a href="#about" class="mobile-link block text-lg font-medium text-[#334155] hover:text-[#0284c7] py-2">About</a>
      <a href="#portfolio" class="mobile-link block text-lg font-medium text-[#334155] hover:text-[#0284c7] py-2">Portfolio</a>
